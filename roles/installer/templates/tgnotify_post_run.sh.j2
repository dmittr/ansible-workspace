#!/bin/bash
# Post-run script for tgnotify
# Generated by ansible installer role

set -e

echo "Running post-installation tasks for tgnotify"

# Deploy tgnotify script
cat > /usr/local/bin/tgnotify << 'TGNOTIFY_EOF'
#!/bin/bash
# Telegram notification script
# Generated by ansible tgnotify role

if [ -f "/etc/telegram.vars" ]; then
  . /etc/telegram.vars
else
  logger -s "tgnotify: Error - /etc/telegram.vars not found."
  exit 1
fi

MESSAGE="${1:-"Empty argument"}"

if [ -z "$TGCHATID" ] || [ -z "$TGBOTID" ]; then
  logger -s "tgnotify: Error - TGCHATID or TGBOTID not set from /etc/telegram.vars."
  exit 1
fi

NOTIFICATION_TEXT="$(hostname): ${MESSAGE}"

# Send the message
curl --max-time 3 -s -X POST "https://api.telegram.org/bot${TGBOTID}/sendMessage" \
  -d "chat_id=${TGCHATID}" -d "text=${NOTIFICATION_TEXT}" > /dev/null 2>&1
TGNOTIFY_EOF

chmod +x /usr/local/bin/tgnotify

# Deploy telegram.vars config
cat > /etc/telegram.vars <> /dev/null

# Deploy startup systemd service
cat > /etc/systemd/system/startup-tg-notify.service << 'SYSTEMD_EOF'
[Unit]
Description=Startup-TG-Notify
After=network.target

[Service]
Type=oneshot
ExecStart=/usr/bin/bash -c '/usr/local/bin/tgnotify "System started!"'
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
SYSTEMD_EOF

chmod 644 /etc/systemd/system/startup-tg-notify.service

# Deploy sudoers file
cat > /etc/sudoers.d/tgnotify << 'SUDOERS_EOF'
ALL ALL = NOPASSWD: /usr/local/bin/tgnotify
SUDOERS_EOF

chmod 440 /etc/sudoers.d/tgnotify

# Deploy login notification script
cat > /etc/profile.d/tg_login_notify.sh << 'LOGIN_EOF'
#!/bin/bash
# Login notification script
# Generated by ansible tgnotify role

if [ -z "$SSH_CONNECTION" ] && [ -z "$SUDO_USER" ]; then
    sudo /usr/local/bin/tgnotify "Login $(whoami) on $(tty)" 2>&1 > /dev/null
fi
LOGIN_EOF

chmod 644 /etc/profile.d/tg_login_notify.sh

# Reload systemd and enable service
systemctl daemon-reload
systemctl enable startup-tg-notify.service

# Send test message
/usr/local/bin/tgnotify "Ansible message" || echo "Failed to send test message"

echo "Post-run completed for tgnotify"
